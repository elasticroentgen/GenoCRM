@page "/loan-projects/{ProjectId:int}/offers/create"
@page "/loan-offers/{OfferId:int}/edit"
@using GenoCRM.Models.Domain
@using GenoCRM.Services.Business
@using Microsoft.AspNetCore.Authorization
@using GenoCRM.Services.Localization
@using GenoCRM.Services.UI
@attribute [Authorize]
@inject ILoanOfferService OfferService
@inject ILoanProjectService ProjectService
@inject NavigationManager Navigation
@inject IStringLocalizer<GenoCRM.SharedResource> L
@inject IModalService ModalService
@inject IFormattingService FormattingService
@rendermode InteractiveServer

<PageTitle>@(_isEdit ? L["Edit"] : L["CreateOffer"])</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@(_isEdit ? L["Edit"] + " " + L["LoanOffer"] : L["CreateOffer"])</h1>
    <button class="btn btn-outline-secondary" @onclick="GoBack">
        <i class="fas fa-arrow-left"></i> @L["Back"]
    </button>
</div>

@if (_hasActiveSubscriptions)
{
    <div class="alert alert-warning d-flex align-items-center mb-4">
        <i class="fas fa-lock me-2"></i>
        @L["EditLimitedActiveSubscriptions"]
    </div>
}

<div class="card">
    <div class="card-body">
        <EditForm Model="_offer" OnValidSubmit="SaveOffer" FormName="loanOfferForm">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">@L["Title"] *</label>
                    <InputText class="form-control" @bind-Value="_offer.Title" />
                    <ValidationMessage For="() => _offer.Title" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">@L["Status"]</label>
                    <InputSelect class="form-select" @bind-Value="_offer.Status">
                        <option value="@LoanOfferStatus.Open">@L["Open"]</option>
                        <option value="@LoanOfferStatus.Closed">@L["Closed"]</option>
                        <option value="@LoanOfferStatus.Cancelled">@L["Cancelled"]</option>
                    </InputSelect>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">@L["InterestRate"] (%) *</label>
                    <InputNumber class="form-control" @bind-Value="_interestRatePercent" step="0.01" disabled="@_hasActiveSubscriptions" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">@L["TermMonths"] *</label>
                    <InputNumber class="form-control" @bind-Value="_offer.TermMonths" disabled="@_hasActiveSubscriptions" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">@L["PaymentInterval"]</label>
                    <InputSelect class="form-select" @bind-Value="_offer.PaymentInterval" disabled="@_hasActiveSubscriptions">
                        <option value="@PaymentInterval.Monthly">@L["Monthly"]</option>
                        <option value="@PaymentInterval.Quarterly">@L["Quarterly"]</option>
                        <option value="@PaymentInterval.SemiAnnual">@L["SemiAnnual"]</option>
                        <option value="@PaymentInterval.Annual">@L["Annual"]</option>
                    </InputSelect>
                </div>
            </div>

            <div class="row">
                <div class="col-md-3 mb-3">
                    <label class="form-label">@L["RepaymentType"]</label>
                    <InputSelect class="form-select" @bind-Value="_offer.RepaymentType" disabled="@_hasActiveSubscriptions">
                        <option value="@RepaymentType.Annuity">@L["Annuity"]</option>
                        <option value="@RepaymentType.BulletLoan">@L["BulletLoan"]</option>
                    </InputSelect>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">@L["GracePeriod"]</label>
                    <div class="input-group">
                        <InputNumber class="form-control" @bind-Value="_offer.GracePeriodMonths" disabled="@_hasActiveSubscriptions" />
                        <span class="input-group-text">@L["Months"]</span>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">@L["MinSubscriptionAmount"]</label>
                    <InputNumber class="form-control" @bind-Value="_offer.MinSubscriptionAmount" disabled="@_hasActiveSubscriptions" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">@L["MaxSubscriptionAmount"]</label>
                    <InputNumber class="form-control" @bind-Value="_offer.MaxSubscriptionAmount" disabled="@_hasActiveSubscriptions" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    <i class="fas fa-save"></i> @L["Save"]
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">@L["Cancel"]</button>
            </div>
        </EditForm>
    </div>
</div>

@if (_interestRatePercent > 0 && _offer.TermMonths > 0)
{
    var exampleAmount = _offer.MinSubscriptionAmount ?? 1000m;
    var yield = CalculateYield(exampleAmount, _interestRatePercent / 100, _offer.TermMonths, _offer.PaymentInterval, _offer.GracePeriodMonths, _offer.RepaymentType);

    <div class="card mt-4 border-info">
        <div class="card-header bg-info bg-opacity-10">
            <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>@L["ExpectedYield"] – @L["ExampleInvestment"]: @FormattingService.FormatCurrency(exampleAmount)</h5>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-4">
                    <div class="fs-4 fw-bold text-info">@FormattingService.FormatCurrency(yield.TotalInterest)</div>
                    <div class="text-muted">@L["InterestAmount"]</div>
                </div>
                <div class="col-md-4">
                    <div class="fs-4 fw-bold text-success">@FormattingService.FormatCurrency(yield.TotalReturn)</div>
                    <div class="text-muted">@L["TotalReturn"]</div>
                </div>
                <div class="col-md-4">
                    <div class="fs-4 fw-bold text-primary">@yield.EffectiveYieldPercent.ToString("F2") %</div>
                    <div class="text-muted">@L["YieldPerYear"]</div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? ProjectId { get; set; }
    [Parameter] public int? OfferId { get; set; }

    private LoanOffer _offer = new() { TermMonths = 12 };
    private decimal _interestRatePercent;
    private bool _isEdit;
    private bool _saving;
    private bool _hasActiveSubscriptions;

    protected override async Task OnInitializedAsync()
    {
        if (OfferId.HasValue)
        {
            _isEdit = true;
            var existing = await OfferService.GetOfferByIdAsync(OfferId.Value);
            if (existing == null)
            {
                Navigation.NavigateTo("/loan-projects");
                return;
            }
            _offer = existing;
            ProjectId = existing.LoanProjectId;
            _interestRatePercent = existing.InterestRate * 100;
            _hasActiveSubscriptions = existing.Subscriptions
                .Any(s => s.Status == LoanSubscriptionStatus.Active);
        }
        else if (ProjectId.HasValue)
        {
            _offer.LoanProjectId = ProjectId.Value;
        }
    }

    private async Task SaveOffer()
    {
        _saving = true;
        try
        {
            _offer.InterestRate = _interestRatePercent / 100;

            if (_isEdit)
            {
                await OfferService.UpdateOfferAsync(_offer);
                Navigation.NavigateTo($"/loan-offers/{_offer.Id}");
            }
            else
            {
                var created = await OfferService.CreateOfferAsync(_offer);
                Navigation.NavigateTo($"/loan-offers/{created.Id}");
            }
        }
        catch (Exception ex)
        {
            await ModalService.ShowErrorAsync(L["Error"], ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private void GoBack()
    {
        if (_isEdit)
            Navigation.NavigateTo($"/loan-offers/{OfferId}");
        else if (ProjectId.HasValue)
            Navigation.NavigateTo($"/loan-projects/{ProjectId}");
        else
            Navigation.NavigateTo("/loan-projects");
    }

    private record YieldResult(decimal TotalInterest, decimal TotalReturn, decimal EffectiveYieldPercent);

    private static YieldResult CalculateYield(decimal principal, decimal annualRate, int termMonths, PaymentInterval interval, int gracePeriodMonths, RepaymentType repaymentType)
    {
        int periodsPerYear = interval switch
        {
            PaymentInterval.Monthly => 12,
            PaymentInterval.Quarterly => 4,
            PaymentInterval.SemiAnnual => 2,
            PaymentInterval.Annual => 1,
            _ => 12
        };

        int totalPeriods = termMonths * periodsPerYear / 12;
        if (totalPeriods <= 0) return new(0, principal, 0);

        decimal periodicRate = annualRate / periodsPerYear;
        decimal totalInterest;

        if (repaymentType == RepaymentType.BulletLoan)
        {
            // Bullet loan: interest on full principal every period
            totalInterest = principal * periodicRate * totalPeriods;
        }
        else
        {
            // Annuity calculation
            decimal annuityPayment;
            if (periodicRate == 0)
            {
                annuityPayment = principal / totalPeriods;
            }
            else
            {
                double r = (double)periodicRate;
                double factor = Math.Pow(1 + r, totalPeriods);
                annuityPayment = principal * (decimal)(r * factor / (factor - 1));
            }

            decimal remaining = principal;
            totalInterest = 0;

            for (int i = 0; i < totalPeriods; i++)
            {
                decimal interest = remaining * periodicRate;
                totalInterest += interest;
                remaining -= (annuityPayment - interest);
            }
        }

        decimal totalReturn = principal + totalInterest;
        decimal termYears = termMonths / 12m;
        decimal effectiveYield = termYears > 0 ? (totalInterest / principal) / termYears * 100 : 0;

        return new(Math.Round(totalInterest, 2), Math.Round(totalReturn, 2), Math.Round(effectiveYield, 4));
    }
}
