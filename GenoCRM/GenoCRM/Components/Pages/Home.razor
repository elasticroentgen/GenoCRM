@page "/"
@inject IStringLocalizer<GenoCRM.SharedResource> Localizer

<PageTitle>@Localizer["Home"]</PageTitle>

<h1>@Localizer["WelcomeMessage"]</h1>

<p>@Localizer["WelcomeMessage"]</p>

<div class="card mt-4 border-primary" style="max-width: 400px;">
    <div class="card-body">
        <h5 class="card-title"><i class="bi bi-question-circle me-2"></i>Hilfe &amp; Übersicht</h5>
        <p class="card-text">Erfahren Sie, wie die einzelnen Bereiche von GenoCRM funktionieren.</p>
        <a href="help" class="btn btn-outline-primary">Zur Hilfe-Seite</a>
    </div>
</div>
